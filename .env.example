# LLM API Keys
GEMINI_API_KEY=your-gemini-api-key
CLAUDE_API_KEY=your-claude-api-key
OPENAI_API_KEY=

# LLM Settings
LLM_RETRY_MAX=3
LLM_RETRY_BACKOFF_BASE=2.0

# Single timeout (seconds) for any `codex exec` subprocess
# (used by both LLMTool and CodexTool — see app/tools/codex_exec.py).
# 600s comfortably covers the worst-case keyword_strategist classify call
# (~10K input + ~10K output tokens through Claude Sonnet).
CODEX_TIMEOUT=600

# ST
ST_MAX_BYTES=249

# Storage
ARTIFACTS_DIR=artifacts/runs
CHECKPOINT_DB=checkpoints.db

# Server
HOST=0.0.0.0
PORT=8000
