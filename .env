# LLM API Keys
GEMINI_API_KEY=your-gemini-api-key
CLAUDE_API_KEY=your-claude-api-key
OPENAI_API_KEY=

# LLM Settings
LLM_RETRY_MAX=3
LLM_RETRY_BACKOFF_BASE=2.0
LLM_TIMEOUT=60

# ST
ST_MAX_BYTES=249

# Storage
ARTIFACTS_DIR=artifacts/runs
CHECKPOINT_DB=checkpoints.db

# Server
HOST=0.0.0.0
PORT=8000
